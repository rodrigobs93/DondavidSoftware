APP_NAME="Mi Negocio POS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Bogota

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mi_pos
DB_USERNAME=mi_pos_user
DB_PASSWORD=mi_pos_pass

SESSION_DRIVER=database
SESSION_LIFETIME=480

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log

# ─── App specific ─────────────────────────────────────────────────────────────
# IP local del PC POS (asignar IP estática en el router o adaptador de red)
APP_LAN_IP=192.168.1.100

# Puerto COM de la impresora térmica USB (verificar en Device Manager)
THERMAL_PRINTER_PORT=COM3

# Fuente de trabajos de impresión: "database" en Fase 1, "api" en Fase 3 nube
PRINT_JOB_SOURCE=database

# Ruta local para copiar backups (puede ser carpeta de OneDrive)
BACKUP_PATH=
